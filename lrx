#!/bin/bash

# Default values
TARGET_DIR="."
SKIP_EXISTING=false

# --- Parse Arguments ---
while getopts "s" opt; do
  case $opt in
    s) SKIP_EXISTING=true ;;
    *) echo "Usage: $0 [-s] [directory]"; exit 1 ;;
  esac
done
shift $((OPTIND -1))

TARGET_DIR="${1:-.}"

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: '$TARGET_DIR' is not a valid directory."
    exit 1
fi

# Check for dependencies
for cmd in jq curl ffprobe metaflac; do
    if ! command -v $cmd &> /dev/null; then
        echo "Error: '$cmd' is not installed."
        exit 1
    fi
done

echo "Scanning: $(realpath "$TARGET_DIR")"
[[ "$SKIP_EXISTING" == true ]] && echo "Mode: Skipping files that already have lyrics."

find "$TARGET_DIR" -type f -name "*.flac" | while read -r file; do
    echo "--------------------------------------------"
    echo "Processing: $file"

    # 1. Check for existing lyrics if -s flag is set
    if [[ "$SKIP_EXISTING" == true ]]; then
        if metaflac --show-tag=UNSYNCEDLYRICS "$file" | grep -q "UNSYNCEDLYRICS="; then
            echo "Skipping: Tag 'UNSYNCEDLYRICS' already exists."
            continue
        fi
    fi

    # 2. Extract metadata
    tags=$(metaflac --export-tags-to=- "$file")
    
    artist=$(echo "$tags" | grep -i "^ARTIST=" | head -n 1 | sed 's/^[^=]*=//; s/^[[:space:]]*//; s/[[:space:]]*$//')
    title=$(echo "$tags" | grep -i "^TITLE=" | head -n 1 | sed 's/^[^=]*=//; s/^[[:space:]]*//; s/[[:space:]]*$//')
    album=$(echo "$tags" | grep -i "^ALBUM=" | head -n 1 | sed 's/^[^=]*=//; s/^[[:space:]]*//; s/[[:space:]]*$//')
    
    duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$file")

    # 3. Safety Check
    if [[ -z "$artist" || -z "$title" ]]; then
        echo "Skipping: Could not find ARTIST or TITLE tags in metadata."
        continue
    fi

    # 4. Query LRCLIB API
    response=$(curl -s -G "https://lrclib.net/api/get" \
        --data-urlencode "artist_name=$artist" \
        --data-urlencode "track_name=$title" \
        --data-urlencode "album_name=$album" \
        --data-urlencode "duration=$duration")

    # 5. Extract and Embed
    if [[ $(echo "$response" | jq 'if . == null then false else true end' 2>/dev/null) == "true" ]]; then
        lyrics=$(echo "$response" | jq -r '.plainLyrics // empty')
    else
        lyrics=""
    fi

    if [[ -n "$lyrics" && "$lyrics" != "null" && "$lyrics" != "false" ]]; then
        echo "Found plain lyrics for '$title'. Embedding..."
        
        metaflac --remove-tag=LYRICS --remove-tag=UNSYNCEDLYRICS "$file"
        
        tmp_lyrics=$(mktemp)
        echo "$lyrics" > "$tmp_lyrics"
        metaflac --set-tag-from-file="UNSYNCEDLYRICS=$tmp_lyrics" "$file"
        rm "$tmp_lyrics"
        
        echo "Success!"
    else
        echo "No plain lyrics found for: $title by $artist"
    fi
done

echo "--------------------------------------------"
echo "Done!"
